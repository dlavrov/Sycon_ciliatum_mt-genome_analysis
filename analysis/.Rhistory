getwd()
composition <- read_tsv(file="./assembly-stat/genes_repeats_combined.tsv",col_names = c("chr","length", "A", "C", "G", "T", "2", "3", "4", "CpG", "tv", "ts", "set")) %>% select(chr:T,set)
composition <- composition %>% mutate(AT = (A+T)/length, GC=(G+C)/length, ATskew=abs((A-T)/(A+T)), GCskew = abs((G-C)/(G+C)))
composition <- composition %>%
mutate(
gene_hit = if_else(str_sub(set, 1, 1) == "g", TRUE, FALSE),
contig   = if_else(str_sub(set, 2, 2) == "c", TRUE, FALSE)
)
View(composition)
summarise(composition,mean_length=mean(length), median_length=median(length),meanGC=mean(GC),sdGC=sd(GC),meanATskew=mean(ATskew),meanGCskew=mean(GCskew))
ggplot(data = composition) + geom_density(mapping = aes(x=length, fill=set), alpha=0.3) + theme_classic() + facet_grid(gene_hit ~ contig)
ggplot(data = composition) + geom_density(mapping = aes(x=length, fill=set), alpha=0.3) + facet_grid(gene_hit ~ contig)
