knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
getwd()
composition <- read_tsv(file="./assembly-stat/genes_repeats_combined.tsv",col_names = c("chr","length", "A", "C", "G", "T", "2", "3", "4", "CpG", "tv", "ts", "CpG-ts")) #%>% select(chr:T)
